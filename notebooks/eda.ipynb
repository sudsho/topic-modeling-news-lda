 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 20 Newsgroups: quick EDA\n",
    "\n",
    "corpus stats, document length distribution, top terms after preprocessing."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "from collections import Counter\n",
    "import matplotlib.pyplot as plt\n",
    "from src.load_data import load_20newsgroups\n",
    "from src.preprocess import tokenize"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "docs, labels = load_20newsgroups()\n",
    "len(docs), len(set(labels))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# raw doc length in chars\n",
    "char_lens = [len(d) for d in docs]\n",
    "plt.hist(char_lens, bins=60)\n",
    "plt.xlabel('chars per doc'); plt.ylabel('count'); plt.title('raw doc length');"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# class balance\n",
    "Counter(labels).most_common()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# top terms post-tokenize on a small subset (full set is slow)\n",
    "sample = docs[:500]\n",
    "tok = [tokenize(d) for d in sample]\n",
    "tok_lens = [len(t) for t in tok]\n",
    "plt.hist(tok_lens, bins=40)\n",
    "plt.xlabel('tokens per doc (post-clean)'); plt.ylabel('count');"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "vocab = Counter(t for ts in tok for t in ts)\n",
    "vocab.most_common(40)"
   ]
  }
 ],
